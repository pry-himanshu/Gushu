<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/offline_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_offline_gradient"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="40dp"
    android:visibility="gone">

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp">
        
        <!-- Glow effect behind logo -->
        <View
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_centerInParent="true"
            android:alpha="0.15"
            android:background="@drawable/ic_launcher_foreground"
            android:backgroundTint="@color/colorPrimary"
            android:scaleX="1.5"
            android:scaleY="1.5" />

        <ImageView
            android:id="@+id/offline_logo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_centerInParent="true"
            android:src="@drawable/gushu" />
    </RelativeLayout>

    <TextView
        android:id="@+id/offline_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="Unable to connect"
        android:textColor="@android:color/white"
        android:textSize="26sp"
        android:letterSpacing="-0.03" />

    <TextView
        android:id="@+id/offline_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="56dp"
        android:gravity="center"
        android:maxWidth="300dp"
        android:text="Your connection was interrupted. Please check your network and try again."
        android:textColor="@color/textMute"
        android:textSize="15sp"
        android:lineSpacingExtra="6dp" />

    <Button
        android:id="@+id/btn_retry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/btn_primary_rounded"
        android:minHeight="56dp"
        android:text="Try Again"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:elevation="4dp"
        android:stateListAnimator="@null" />

    <TextView
        android:id="@+id/offline_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:alpha="0.25"
        android:text="Gushu Secure Messenger"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.4"
        android:fontFamily="sans-serif-light" />

</LinearLayout>
